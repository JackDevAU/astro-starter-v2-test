---
import BlogPost from '../../layouts/BlogPost.astro';
import BlogPostBody from '../../components/BlogPostBody.astro';
import TinaIsland from '@tinacms/astro/TinaIsland.astro';
import { getBlogPost } from '../../lib/data';
import { islands } from '../../lib/islands';

export const prerender = false;

const slug = (Astro.params.slug ?? '').toString();
const relativePath = `${slug}.mdx`;
const result = await getBlogPost(relativePath);
if (!result.data?.blog) {
	return new Response('Not Found', { status: 404 });
}
const data = result.data.blog;
---
<BlogPost
	title={data.title}
	description={data.description ?? ''}
>
	<TinaIsland name="blogPost" wrapper={islands.blogPost.wrapper} params={{ relativePath }}>
		<BlogPostBody data={data} />
	</TinaIsland>
</BlogPost>
